<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Task Manager</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
</head>

<body class="bg-gradient-to-br from-blue-50 to-indigo-100 min-h-screen flex items-center justify-center p-4">
    <div
        class="bg-white rounded-xl shadow-2xl p-8 max-w-4xl w-full transition-all duration-300 hover:shadow-3xl hover:scale-105">
        <h1 class="text-4xl font-bold text-center text-gray-800 mb-8">
            <i class="fas fa-tasks text-indigo-600 mr-3"></i>
            Task Manager App
        </h1>
        <form class="mb-10 space-y-4" action="/create-task" method="post">
            <div class="flex flex-col md:flex-row gap-4">
                <input type="text" name="title" placeholder="Enter your task title"
                    class="flex-1 border-2 border-gray-300 rounded-lg p-3 outline-none focus:border-indigo-500 focus:ring-2 focus:ring-indigo-200 transition-all duration-200">
                <button type="submit"
                    class="bg-indigo-600 hover:bg-indigo-700 text-white px-6 py-3 rounded-lg transition-all duration-200 hover:scale-105 flex items-center justify-center">
                    <i class="fas fa-plus mr-2"></i>Add Task
                </button>
            </div>
            <textarea name="details"
                class="w-full border-2 border-gray-300 rounded-lg p-3 outline-none focus:border-indigo-500 focus:ring-2 focus:ring-indigo-200 transition-all duration-200 resize-none"
                rows="3" placeholder="Enter task details"></textarea>
        </form>
        <div>
            <h2 class="text-2xl font-semibold text-gray-700 mb-6 flex items-center">
                <i class="fas fa-list-check text-green-600 mr-2"></i>
                Your Tasks
            </h2>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                <% if(files.length>0){ %>
                    <% files.forEach(file=>{ %>
                        <div
                            class="bg-gray-50 p-6 rounded-lg shadow-md hover:shadow-lg transition-all duration-300 hover:scale-105 border border-gray-200">
                            <div class="flex justify-between items-start mb-4">
                                <h3 class="text-xl font-semibold text-gray-800">
                                    <%= file.replace('.txt', '').charAt(0).toUpperCase() + file.replace('.txt', '').slice(1) %>
                                </h3>
                                <form action="/delete" method="post">
                                    <input type="hidden" name="filename" value="<%=file.replace('.txt', '')%>">
                                    <button type="submit" class="bg-red-500 hover:bg-red-600 text-white px-3 py-1 rounded-lg transition-all duration-200 hover:scale-105 flex items-center">
                                        <i class="fas fa-trash mr-1"></i>Delete
                                    </button>
                                </form>
                            
                            </div>
                            <div class="space-y-2">
                                <a href="/task?filename=<%=file.replace('.txt', '')%>"
                                    class="text-indigo-600 hover:text-indigo-800 font-medium flex items-center transition-colors duration-200">
                                    <i class="fas fa-eye mr-2"></i>View Details
                                </a>
                                <a href="/edit?filename=<%=file.replace('.txt', '')%>"
                                    class="text-green-600 hover:text-green-800 font-medium flex items-center transition-colors duration-200">
                                    <i class="fas fa-edit mr-2"></i>Edit Task
                                </a>
                            </div>
                        </div>
                        <% }) %>
                            <%} else{ %>
                                <div class="col-span-full text-center py-12">
                                    <i class="fas fa-inbox text-6xl text-gray-300 mb-4"></i>
                                    <h3 class="text-xl font-medium text-gray-500">No tasks available</h3>
                                    <p class="text-gray-400 mt-2">Create your first task to get started!</p>
                                </div>
                                <% } %>
            </div>
        </div>
    </div>
</body>

</html>